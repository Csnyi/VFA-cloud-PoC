# VFA Cloud PoC — environment configuration
#
# Copy this file to .env and set the values before running.
#
#   cp .env.example .env

# -------------------------------------------------------------------
# Required
# -------------------------------------------------------------------

# HMAC secret used by the policy server to sign and verify visa tokens.
# Use a strong random value in any shared or non-local environment.
# Example: openssl rand -hex 32
VFA_HMAC_SECRET=change-me-use-a-strong-random-value

# -------------------------------------------------------------------
# Optional — override defaults shown below
# -------------------------------------------------------------------

# Visa token lifetime in seconds (default: 300).
# The VFA-Spec recommends ≤ 60 s for production deployments.
# VFA_TOKEN_TTL_SECONDS=300

# VFA session lifetime in seconds (default: 300).
# VFA_SESSION_TTL_SECONDS=300
